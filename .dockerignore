# Keep image build context lean and free of secrets / dev junk.

# --- VCS & docs --------------------------------------------------------------
.git
.gitignore
.gitattributes
*.md
docs/
README*

# --- Environment & secrets ---------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
service-account*.json
vault-token

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/

# --- uv cache (image gets its own) ------------------------------------------
.uv-cache/

# --- Testing & coverage ------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
tests/

# --- Node ---------------------------------------------------------------------
node_modules/
frontend/widget/dist/
frontend/widget/.vite/

# --- IDE / OS ----------------------------------------------------------------
.idea/
.vscode/
.DS_Store
Thumbs.db

# --- Compose / Docker (do not copy the orchestration into images) ----------
docker/
docker-compose*.yml
Dockerfile*
