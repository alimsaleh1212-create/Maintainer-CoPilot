# =============================================================================
# Maintainer's Copilot — environment template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. Never commit real secrets.
# vault-init reads these and seeds them into Vault on every stack start.
# =============================================================================

# --- Vault -------------------------------------------------------------------
# Dev-mode root token — must match VAULT_DEV_ROOT_TOKEN_ID in docker-compose.yml.
# Leave as-is for local dev; change for any shared/staging environment.
VAULT_ROOT_TOKEN=dev-token-local
VAULT_ADDR=http://vault:8200

# --- LLM API keys (REQUIRED) -------------------------------------------------
# Get your Gemini key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- LLM model names ---------------------------------------------------------
# Gemini: gemini-2.5-flash (fast), gemini-2.5-pro (best), gemini-2.0-flash (cheap)
GEMINI_MODEL=gemini-2.0-flash
# Ollama chat: must be pulled first — run: ollama pull gemma3:4b
OLLAMA_CHAT_MODEL=gemma3:4b
# Ollama embeddings (pulled automatically on stack start)
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Database ----------------------------------------------------------------
# Password for the copilot Postgres user. Leave as-is for local dev.
# Change before deploying to any shared environment.
POSTGRES_PASSWORD=copilot

# --- Auth --------------------------------------------------------------------
# JWT signing key — any long random string is fine for local dev.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SIGNING_KEY=dev-jwt-signing-key-change-in-production

# --- MinIO (object storage) --------------------------------------------------
# Also used as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yml.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Langfuse (LLM tracing) --------------------------------------------------
# Leave placeholder values for local dev (tracing UI still works, traces may
# not authenticate but the app boots fine).
# For real Langfuse: sign up at langfuse.com or run self-hosted.
LANGFUSE_PUBLIC_KEY=dev-langfuse-public-key
LANGFUSE_SECRET_KEY=dev-langfuse-secret-key

# --- Service ports (host-side) -----------------------------------------------
API_PORT=8000
STREAMLIT_PORT=8501
WIDGET_PORT=8081
MODEL_SERVER_PORT=8001
HOST_PORT_ALLOWED=8090
HOST_PORT_DISALLOWED=8091
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
VAULT_PORT=8200
LANGFUSE_PORT=3000
OLLAMA_PORT=11434
PGADMIN_PORT=5050

# --- pgAdmin (dev DB browser) ------------------------------------------------
PGADMIN_EMAIL=admin@dev.local
PGADMIN_PASSWORD=admin
# pgadmin password is NOT seeded to Vault — it is a local dev UI only.
