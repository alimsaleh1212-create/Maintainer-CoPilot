# =============================================================================
# Maintainer's Copilot — example environment
#
# Per CLAUDE.md (Secrets rule): this file carries ONLY the Vault root token and
# service ports. Every real secret (LLM keys, DB password, JWT signing key,
# tracing keys, MinIO creds) is resolved from Vault at app startup.
#
# DO NOT add API keys or passwords here. Add them inside Vault.
# =============================================================================

# --- Vault -------------------------------------------------------------------
# Paste your local Vault dev-mode root token. The compose stack starts Vault in
# dev mode; the token is printed in its container logs on first boot.
VAULT_ROOT_TOKEN=
VAULT_ADDR=http://vault:8200

# --- Service ports (host-side) ----------------------------------------------
API_PORT=8000
STREAMLIT_PORT=8501
WIDGET_PORT=8081
MODEL_SERVER_PORT=8001
HOST_PORT_ALLOWED=8090
HOST_PORT_DISALLOWED=8091
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
VAULT_PORT=8200
LANGFUSE_PORT=3000
